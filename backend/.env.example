# Database
DATABASE_URL=postgresql://username:password@localhost:5432/experimentx

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-chars

# CORS — comma separated, no spaces
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Production example:
# ALLOWED_ORIGINS=https://experimentx.vercel.app,https://experimentx.io